---
import "@fontsource/jetbrains-mono";
import jetbrainsMono400 from "@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url";
import jetbrainsMono700 from "@fontsource/jetbrains-mono/files/jetbrains-mono-latin-700-normal.woff2?url";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#282828" />

    <title>Nick Chaloult</title>
    <meta name="description" content="Nick Chaloult's personal site" />

    <!-- Prefetching fonts -->

    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={jetbrainsMono400}
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={jetbrainsMono700}
      crossorigin="anonymous"
    />
    <!-- "new-spirit" font from Adobe Fonts. -->
    <link rel="preconnect" href="https://use.typekit.net" />
    <link rel="stylesheet" href="https://use.typekit.net/iyr6yes.css" />
    <!-- Figtree -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph tags -->
    <meta property="og:title" content="Nick Chaloult" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://nchaloult.com" />
    <meta property="og:description" content="Nick Chaloult's personal site" />
    <!-- <meta property="og:image" content="https://www.example.com/_astro/seo-banner.BZD7kegZ.webp"> -->
    <!-- <meta property="og:image:alt" content=""> -->
  </head>
  <body>
    <slot />
  </body>
</html>
