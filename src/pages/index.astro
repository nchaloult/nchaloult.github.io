---
import Layout from "../layouts/Layout.astro";
import ManPage from "../components/ManPage.astro";
import QuoteCard from "../components/QuoteCard.tsx";
import ArticleLink from "../components/ArticleLink.astro";
---

<Layout>
  <div class="flex flex-col items-center p-8 gap-8">
    <QuoteCard client:load />
    <main class="w-full max-w-6xl grid grid-cols-2 gap-16">
      <div class="flex flex-col gap-8">
        <h1 class="text-2xl">Writing</h1>

        <ArticleLink
          title="You cannot study your way to greatness with LLMs"
          href="#"
          date="February 8, 2026"
        />
        <ArticleLink
          title="Simpler is better / There are no templates"
          href="#"
          date="December 12, 2025"
        />
        <ArticleLink title="Why I write" href="#" date="October 17, 2025" />
      </div>
      <ManPage />
    </main>
  </div>
</Layout>
