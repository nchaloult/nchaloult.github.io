---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import ManPage from "../components/ManPage.astro";
import QuoteCard from "../components/QuoteCard.tsx";
import ArticleLink from "../components/ArticleLink.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout>
  <div class="flex flex-col items-center p-8 gap-8">
    <QuoteCard client:load />
    <main class="w-full max-w-6xl grid grid-cols-2 gap-16">
      <div class="flex flex-col gap-8">
        <h1 class="text-3xl">Writing</h1>

        {
          posts.map((post) => (
            <ArticleLink
              title={post.data.title}
              subtitle={post.data.subtitle}
              href={`/blog/${post.id}`}
              date={post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
                timeZone: "UTC",
              })}
            />
          ))
        }
      </div>
      <ManPage />
    </main>
  </div>
</Layout>
