---
import { getCollection, render } from "astro:content";
import { Image, getImage } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import HomeLink from "../../components/HomeLink.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const WORDS_PER_MINUTE = 175;
const wordCount = post.body?.trim().split(/\s+/).length ?? 0;
const readTimeMinutes = Math.max(1, Math.ceil(wordCount / WORDS_PER_MINUTE));

// Resolve the hero image at build time to get its optimized src for preloading.
const heroImage = post.data.heroImage;
const resolvedHeroImage = heroImage
  ? await getImage({ src: heroImage, format: "webp" })
  : null;
---

<Layout>
  {
    resolvedHeroImage && (
      <head>
        <link
          rel="preload"
          as="image"
          type="image/webp"
          href={resolvedHeroImage.src}
        />
      </head>
    )
  }
  <div class="flex justify-center p-8">
    <div class="w-full max-w-2xl flex flex-col gap-8">
      <nav>
        <HomeLink />
      </nav>

      <article class="w-full max-w-2xl flex flex-col gap-8">
        <header class="flex flex-col gap-2 border-b border-gruvbox-bg1 pb-4">
          <div class="flex gap-4 text-sm text-gruvbox-teal">
            <time>
              {
                post.data.publishDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                  timeZone: "UTC",
                })
              }
            </time>
            <span aria-hidden="true">·</span>
            <small class="text-sm">{readTimeMinutes} min read</small>
          </div>
          <h1 class="text-3xl font-bold font-['new-spirit']">
            {post.data.title}
          </h1>
          <h2 class="text-base text-gruvbox-gray">{post.data.subtitle}</h2>
        </header>
        <div class="flex flex-col gap-2">
          {
            heroImage && (
              <Image
                src={heroImage}
                alt={post.data.heroCaption ?? ""}
                class="w-full h-auto rounded-lg"
                loading="eager"
                fetchpriority="high"
                format="webp"
              />
            )
          }
          {
            post.data.heroCaption && (
              <figcaption class="flex flex-col gap-2 text-sm text-gruvbox-gray">
                {post.data.heroCaption}
                {post.data.heroSourceURL && (
                  <a
                    href={post.data.heroSourceURL}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {post.data.heroSourceURL}
                  </a>
                )}
              </figcaption>
            )
          }
        </div>
        <div
          class="prose prose-invert prose-headings:font-heading text-gruvbox-text prose-headings:text-gruvbox-green prose-strong:text-gruvbox-text prose-li:text-gruvbox-text prose-a:text-gruvbox-yellow prose-a:no-underline prose-a:hover:underline [--tw-prose-bullets:var(--color-gruvbox-text)] [--tw-prose-counters:var(--color-gruvbox-text)] [--tw-prose-quote-borders:var(--color-gruvbox-bg1)] prose-blockquote:not-italic [&_blockquote_p]:font-['new-spirit'] [&_blockquote_p]:text-gruvbox-text [&_blockquote_footer_cite]:text-gruvbox-teal [&_blockquote_footer_cite]:not-italic"
        >
          <Content />
        </div>
      </article>

      <nav>
        <HomeLink />
      </nav>
    </div>
  </div>
</Layout>
